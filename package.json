{
  "name": "yue-bot-discord",
  "version": "1.0.0",
  "private": true,
  "description": "Bot Discord multifuncional com Web UI - Moderação e Sorteios",
  "author": "Yue Bot Team",
  "license": "AGPL-3.0-only",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "pnpm --filter database db:generate && pnpm --filter @yuebot/shared build && pnpm --filter @yuebot/database build && pnpm --filter bot deploy-commands && pnpm --filter database db:migrate:safe && pnpm --parallel --stream run dev",
    "dev:bot": "pnpm --filter bot dev",
    "dev:api": "pnpm --filter api dev",
    "dev:web": "pnpm --filter web dev",
    "bot:deploy-commands": "pnpm --filter bot deploy-commands",
    "bot:lint": "pnpm --filter bot lint",
    "bot:type-check": "pnpm --filter bot type-check",
    "build": "pnpm -r run build",
    "build:bot": "pnpm --filter bot build",
    "build:api": "pnpm --filter api build",
    "build:web": "pnpm --filter web build",
    "db:generate": "pnpm --filter database db:generate",
    "db:push": "pnpm --filter database db:push",
    "db:migrate": "pnpm --filter database db:migrate",
    "db:migrate:safe": "pnpm --filter database db:migrate:safe",
    "db:studio": "pnpm --filter database db:studio",
    "lint": "pnpm -r run lint",
    "type-check": "pnpm -r --workspace-concurrency=1 run type-check",
    "knip": "knip",
    "clean": "pnpm -r run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/github": "^12.0.6",
    "@semantic-release/release-notes-generator": "^14.1.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^10.2.1",
    "globals": "^17.5.0",
    "knip": "^6.6.1",
    "semantic-release": "^25.0.3",
    "typescript": "^6.0.3"
  },
  "engines": {
    "node": ">=24.0.0",
    "pnpm": ">=10.0.0"
  },
  "pnpm": {
    "overrides": {
      "rollup": ">=4.59.0",
      "hono": ">=4.12.7",
      "@hono/node-server": ">=1.19.10",
      "flatted": ">=3.4.2",
      "undici": ">=6.24.0",
      "effect": ">=3.20.0",
      "lodash": ">=4.17.23",
      "bn.js": ">=4.12.3"
    },
    "onlyBuiltDependencies": [
      "@prisma/engines",
      "esbuild",
      "msgpackr-extract",
      "prisma"
    ]
  },
  "packageManager": "pnpm@10.32.1",
  "dependencies": {
    "@types/node": "^25.6.0"
  }
}