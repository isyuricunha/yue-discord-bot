{
  "name": "@yuebot/web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "pnpm --filter @yuebot/shared build && vite",
    "build": "pnpm --filter @yuebot/shared build && tsc && vite build",
    "type-check": "pnpm --filter @yuebot/shared build && tsc --noEmit",
    "preview": "vite preview",
    "lint": "eslint \"src/**/*.{ts,tsx}\" --max-warnings 0",
    "test": "pnpm --filter @yuebot/shared build && vitest run"
  },
  "dependencies": {
    "@tanstack/react-query": "^5.99.0",
    "@yuebot/shared": "workspace:*",
    "axios": "^1.15.0",
    "clsx": "^2.1.1",
    "lucide-react": "^0.562.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.14.1",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.5.0",
    "postcss": "^8.5.9",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vitest": "^4.1.4"
  }
}
