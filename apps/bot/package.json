{
  "name": "@yuebot/bot",
  "version": "1.0.0",
  "private": true,
  "main": "./dist/index.js",
  "scripts": {
    "dev": "pnpm --filter @yuebot/shared build && pnpm --filter @yuebot/database build && tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "deploy-commands": "tsx src/bin/deploy-commands.ts",
    "test": "node --test --import tsx src/**/*.test.ts",
    "clean": "rm -rf dist",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "type-check": "pnpm --filter @yuebot/shared build && pnpm --filter @yuebot/database build && tsc --noEmit"
  },
  "dependencies": {
    "@mistralai/mistralai": "^2.2.5",
    "@napi-rs/canvas": "^1.0.0",
    "@yuebot/database": "workspace:*",
    "@yuebot/shared": "workspace:*",
    "axios": "^1.16.1",
    "bullmq": "^5.78.0",
    "discord.js": "^14.26.4",
    "ioredis": "5.11.0",
    "kazagumo": "^3.4.3",
    "luxon": "^3.7.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "png-chunk-text": "^1.0.0",
    "png-chunks-encode": "^1.0.0",
    "png-chunks-extract": "^1.0.0",
    "redis": "^6.0.0",
    "shoukaku": "^4.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3"
  }
}