{
  "name": "@yuebot/bot",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "dev": "pnpm --filter @yuebot/shared build && pnpm --filter @yuebot/database build && tsx watch src/index.ts",
    "build": "tsup",
    "start": "node dist/index.js",
    "deploy-commands": "tsx src/bin/deploy-commands.ts",
    "test": "node --test --import tsx src/**/*.test.ts",
    "clean": "rm -rf dist",
    "lint": "eslint \"src/**/*.{ts,tsx}\"",
    "type-check": "pnpm --filter @yuebot/shared build && pnpm --filter @yuebot/database build && tsc --noEmit"
  },
  "dependencies": {
    "@mistralai/mistralai": "^2.0.0",
    "@napi-rs/canvas": "^0.1.88",
    "@yuebot/database": "workspace:*",
    "@yuebot/shared": "workspace:*",
    "axios": "^1.10.0",
    "bullmq": "^5.70.4",
    "discord.js": "^14.25.1",
    "ioredis": "5.10.0",
    "kazagumo": "^3.4.3",
    "luxon": "^3.7.2",
    "pino": "^10.2.0",
    "pino-pretty": "^13.1.3",
    "png-chunk-text": "^1.0.0",
    "png-chunks-encode": "^1.0.0",
    "png-chunks-extract": "^1.0.0",
    "redis": "^5.10.0",
    "shoukaku": "^4.3.0"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}