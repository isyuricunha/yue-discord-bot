# Local development (HTTP)
#
# Copy this file to .env.local to override values from .env without changing your base config:
#   cp .env.local.example .env.local
#
# This file is intended for local-only development over HTTP (localhost).

# Discord Bot
DISCORD_TOKEN=
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=1434271732507611289
DISCORD_CLIENT_SECRET=

# Database
DATABASE_URL=postgresql://yuebot_user:yuebot_password@localhost:5432/yuebot

# Redis used by BullMQ
REDIS_URL="redis://127.0.0.1:6379"

# Lavalink Nodes (JSON Array format)
# Example: [{"name": "Node 1", "url": "localhost:2333", "auth": "youshallnotpass", "secure": false}]
LAVALINK_NODES='[{"name": "Public Node", "url": "lavalink.example.com:443", "auth": "password", "secure": true}]'
LAVALINK_DISABLED_NODES=
REDIS_PASSWORD=

# API
API_PORT=3000
PORT=
API_HOST=0.0.0.0
TRUST_PROXY=0
API_BODY_LIMIT=10485760
JWT_SECRET=change_me_to_a_long_random_jwt_secret_min_32_chars
JWT_EXPIRES_IN=7d

# Internal API (API <-> Bot)
INTERNAL_API_SECRET=change_me_to_a_long_random_secret
BOT_INTERNAL_HOST=127.0.0.1
BOT_INTERNAL_PORT=3100
INTERNAL_API_CACHE_TTL_MS=20000
INTERNAL_API_CACHE_MAX_ENTRIES=500
KEYWORD_TRIGGER_CACHE_TTL_MS=10000
SUGGESTION_CONFIG_CACHE_TTL_MS=10000

# Admin allowlists (comma-separated)
BADGE_ADMIN_USER_IDS=
FAN_ART_REVIEWER_USER_IDS=

# OpenAI (moderação automática via IA — omni-moderation-latest)
# Deixe em branco para desativar a moderação por IA.
OPENAI_API_KEY=
OPENAI_MODERATION_IMAGE_MAX_BYTES=20971520
OPENAI_MODERATION_IMAGE_PAYLOAD_MAX_BYTES=47185920

# CORS (separar por vírgula)
# Ex: CORS_ORIGINS=https://seu-front.vercel.app,https://seu-dominio.com
CORS_ORIGINS=http://localhost:5173

# Cookies (para sessão via httpOnly cookie)
# Para frontend em outro domínio: COOKIE_SAMESITE=none e COOKIE_SECURE=true
COOKIE_SAMESITE=lax
COOKIE_SECURE=false
COOKIE_DOMAIN=

# Web UI
WEB_PORT=5173
WEB_URL=http://localhost:5173
API_URL=http://localhost:3000

# Web UI (Vite build-time)
VITE_API_URL=http://localhost:3000
VITE_DISCORD_CLIENT_ID=1434271732507611289

# Frontend URL (alias usado no Docker e na API)
FRONTEND_URL=http://localhost:5173

# OAuth2
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/callback

# LivePix support payments (optional)
LIVEPIX_ENABLED=false
LIVEPIX_CLIENT_ID=
LIVEPIX_CLIENT_SECRET=
LIVEPIX_OAUTH_REDIRECT_URI=http://localhost:3000/api/livepix/oauth/callback
LIVEPIX_WEBHOOK_URL=http://localhost:3000/api/livepix/webhook
LIVEPIX_PAYMENT_RETURN_URL=http://localhost:3000/api/livepix/return
LIVEPIX_TOKEN_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef
LIVEPIX_OWNER_GUILD_IDS=

# Environment
NODE_ENV=development

# Logging
LOG_LEVEL=info

# Sentry (opcional)
SENTRY_DSN=

# Mistral (Discord AI and optional panel runtime)
# MISTRAL_API_KEY is required to enable Discord AI. MISTRAL_AGENT_ID is optional for tools.
# To generate images in chat, configure an agent that has the Mistral image_generation connector.
MISTRAL_API_KEY=
MISTRAL_AGENT_ID=
MISTRAL_IMAGE_AGENT_ID=
MISTRAL_PANEL_AGENT_ID=

# Prompt file path (relative paths are resolved from the process working directory)
# When running the bot via pnpm (cwd=apps/bot), use a repo-root relative path.
MISTRAL_PROMPT_PATH=../../prompts/system_prompt.txt

# Model params (used for chat calls; agents are configured on the Mistral side)
MISTRAL_MODEL=mistral-small-latest
MISTRAL_TEMPERATURE=0.2
MISTRAL_MAX_TOKENS=512

# Panel AI (optional; credentials remain environment-only)
# Custom Provider can be Ella's primary text runtime or fallback text runtime.
# Model and reasoning mode are selected in the Owner panel.
CUSTOM_PROVIDER_BASE_URL=
CUSTOM_PROVIDER_API_KEY=
DISCORD_AI_CHAT_TIMEOUT_MS=90000
# Path to the Custom Provider persona file (relative or absolute).
# When the file is missing or empty, a safe functional fallback persona is used.
PANEL_AI_PROMPT_PATH=/app/prompts/panel_ai_system_prompt.txt
PANEL_AI_CHAT_TIMEOUT_MS=90000
CUSTOM_PROVIDER_MODEL_LIST_TIMEOUT_MS=300000
REDIS_CONNECT_TIMEOUT_MS=3000
REDIS_COMMAND_TIMEOUT_MS=3000
GAMERPOWER_CACHE_TTL_MS=600000
